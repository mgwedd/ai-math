# Copy to .env to override defaults (defaults work out of the box).
# `docker compose up -d --build` self-hosts Minima with local email/password
# auth (GoTrue) — no cloud Supabase. See docs/DEPLOYMENT.md.
APP_PORT=3000
POSTGRES_PORT=5433
POSTGRES_USER=aimath
POSTGRES_PASSWORD=aimath_dev
POSTGRES_DB=aimath

# Host port the Supabase-auth proxy (nginx -> GoTrue) is published on.
SUPABASE_PROXY_PORT=8000

# NOTE: the local JWT secret + anon key are the well-known Supabase demo values,
# hardcoded in docker-compose.yml. They are LOCAL ONLY and MUST be changed for
# any real / internet-facing deployment (docs/DEPLOYMENT.md).

# --- Knowledge-base enrichment (OPTIONAL) ---------------------------------
# Server-side only; the browser never sees this. When set, GET /api/kb/concept
# enriches concept cards with cached Wolfram|Alpha pods (the "verify & compute"
# wellspring). Leave UNSET and the app works exactly as before — Wikipedia
# summaries still appear (no key needed) and Wolfram fields are simply omitted.
# Get a free non-commercial AppID at https://developer.wolframalpha.com/.
# WOLFRAM_APP_ID=

# --- Knowledge-base generation pipeline (OPTIONAL, maintainer-only) -------
# Only used by the batch scripts (`npm run kb:generate`, `npm run kb:promote`)
# and the scheduled kb-topup workflow — never read by the running app/routes.
# See docs/DEPLOYMENT.md "Knowledge base operations" for the full loop.
# ANTHROPIC_API_KEY=
# Model id used by kb:generate; defaults to a current mid-tier Claude model if unset.
# KB_GENERATE_MODEL=
# Auto-promote policy knobs for kb:promote --auto (conservative defaults; see
# scripts/kb-promote.mjs). KB_AUTO_PROMOTE_MIN_VERIFIED=5, require_match=true.
# KB_AUTO_PROMOTE_MIN_VERIFIED=
# KB_AUTO_PROMOTE_REQUIRE_MATCH=

# --- Per-user KB rate caps (OPTIONAL) --------------------------------------
# Durable daily per-user caps on the KB routes (lib/kb/rate-limit.js), backed
# by the kb_usage table. Generous built-in defaults; override per route if
# needed. Fails OPEN on any DB/table error — never blocks users on an infra
# hiccup. See docs/DEPLOYMENT.md "Knowledge base operations".
# KB_CONCEPT_DAILY_CAP=
# KB_STEPS_DAILY_CAP=
# PRACTICE_DAILY_CAP=
# KB_RATE_LIMIT_DEFAULT_CAP=
