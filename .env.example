# Copy to .env to override defaults (defaults work out of the box).
# `docker compose up -d --build` self-hosts Minima with local email/password
# auth (GoTrue) — no cloud Supabase. See docs/DEPLOYMENT.md.
APP_PORT=3000
POSTGRES_PORT=5433
POSTGRES_USER=aimath
POSTGRES_PASSWORD=aimath_dev
POSTGRES_DB=aimath

# Host port the Supabase-auth proxy (nginx -> GoTrue) is published on.
SUPABASE_PROXY_PORT=8000

# NOTE: the local JWT secret + anon key are the well-known Supabase demo values,
# hardcoded in docker-compose.yml. They are LOCAL ONLY and MUST be changed for
# any real / internet-facing deployment (docs/DEPLOYMENT.md).

# --- Knowledge-base enrichment (OPTIONAL) ---------------------------------
# Server-side only; the browser never sees this. When set, GET /api/kb/concept
# enriches concept cards with cached Wolfram|Alpha pods, and POST /api/kb/steps
# powers the "Show the steps" button on missed numeric questions (the "verify &
# compute" wellspring — Show Steps is an extension of the Full Results API).
# Leave UNSET and the app works exactly as before — Wikipedia summaries still
# appear (no key needed), Wolfram pods are omitted, and the steps button never
# shows (a keyless capability probe hides it), so the UI is pixel-identical.
# Get a free non-commercial AppID at https://developer.wolframalpha.com/.
# WOLFRAM_APP_ID=
